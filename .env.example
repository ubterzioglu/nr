# Supabase (opsiyonel — tanımlı değilse site veritabanısız çalışır)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Admin panel ortak şifresi (geçiş dönemi). Kalıcı yöntem: Supabase Auth +
# users.admin_role. Admin hesapları atandıktan sonra ADMIN_LEGACY_LOGIN=false
# ile ortak şifre girişini kapatın.
ADMIN_SECRET=
ADMIN_LEGACY_LOGIN=

# SMTP — form bildirimleri için zorunlu (Gmail: uygulama şifresi kullanın)
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=
FORM_NOTIFICATION_EMAIL=


https://pyjnelmqzrzvvzccdlzk.supabase.co/auth/v1/callback
